---
import Layout from '../../layouts/Layout.astro';
import CTA from '../../components/CTA.astro';
import VideoCarousel from '../../components/VideoCarousel.astro';
import { business, services } from '../../data/business';
---
<Layout
  title="Stump Grinding Services | Mark's Stump Removal | Greenville, SC"
  description="Stump grinding, root removal, land clearing, and emergency stump services in Greenville, SC and Upstate South Carolina. Free estimates — call or text (864) 214-5623."
>
  <section class="bg-forest text-white py-16">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Our Stump Grinding Services</h1>
      <p class="text-xl text-gray-200">Professional equipment. Clean results. Fair prices.</p>
    </div>
  </section>

  <VideoCarousel />

  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      {services.map((service, i) => (
        <div class={`mb-16 ${i > 0 ? 'pt-16 border-t border-gray-200' : ''}`} id={service.slug}>
          <h2 class="text-3xl font-bold text-forest mb-4">{service.title}</h2>
          <p class="text-gray-600 text-lg mb-6">{service.long}</p>
          <ul class="space-y-2 text-gray-600 mb-6">
            {service.benefits.map(b => (
              <li class="flex items-start gap-2">
                <span class="text-green font-bold mt-0.5">&#10003;</span>
                <span>{b}</span>
              </li>
            ))}
          </ul>
          <a href={`/services/${service.slug}/`} class="text-green font-bold hover:text-forest transition-colors">
            Learn more about {service.title.toLowerCase()}
          </a>
        </div>
      ))}
    </div>
  </section>

  <!-- Process -->
  <section class="py-16 bg-cream">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-center text-forest mb-10">How It Works</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-14 h-14 bg-earth text-forest rounded-full flex items-center justify-center mx-auto mb-4 text-2xl font-bold">1</div>
          <h3 class="text-lg font-bold text-forest mb-2">Text Us a Photo</h3>
          <p class="text-gray-600">Snap a photo of the stump from 10-15 feet away and text it to {business.phone}.</p>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 bg-earth text-forest rounded-full flex items-center justify-center mx-auto mb-4 text-2xl font-bold">2</div>
          <h3 class="text-lg font-bold text-forest mb-2">Get Your Free Quote</h3>
          <p class="text-gray-600">We review the photo and reply with a fair, no-obligation estimate — usually within hours.</p>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 bg-earth text-forest rounded-full flex items-center justify-center mx-auto mb-4 text-2xl font-bold">3</div>
          <h3 class="text-lg font-bold text-forest mb-2">We Grind It Out</h3>
          <p class="text-gray-600">We show up on schedule, grind the stump below grade, clean up, and leave your yard spotless.</p>
        </div>
      </div>
    </div>
  </section>

  <CTA />
</Layout>
