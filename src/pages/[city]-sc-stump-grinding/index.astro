---
import Layout from '../../layouts/Layout.astro';
import CTA from '../../components/CTA.astro';
import Stars from '../../components/Stars.astro';
import { cities, business, services } from '../../data/business';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return cities.map(city => ({
    params: { city: city.slug },
    props: { city },
  }));
};

const { city } = Astro.props;
---
<Layout
  title={`Stump Grinding in ${city.name}, SC | Mark's Stump Removal`}
  description={`Professional stump grinding in ${city.name}, South Carolina. 5-star rated, free estimates. Call or text Mark's Stump Removal at (864) 214-5623.`}
>
  <section class="bg-forest text-white py-16">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <Stars />
      <h1 class="text-4xl md:text-5xl font-bold mt-6 mb-4">Stump Grinding in {city.name}, SC</h1>
      <p class="text-xl text-gray-200 max-w-2xl mx-auto">Professional stump removal for {city.name} homeowners and businesses. Free estimates — text us a photo.</p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <p class="text-gray-600 text-lg mb-8">{city.description}</p>

      <h2 class="text-2xl font-bold text-forest mb-6">Stump Grinding Services in {city.name}</h2>
      <div class="grid md:grid-cols-2 gap-4 mb-12">
        {services.map(service => (
          <div class="bg-cream rounded-xl p-5">
            <div class="flex items-center gap-2 mb-2">
              <span class="text-2xl">{service.icon}</span>
              <h3 class="font-bold text-forest">{service.title}</h3>
            </div>
            <p class="text-gray-600 text-sm">{service.short}</p>
          </div>
        ))}
      </div>

      <h2 class="text-2xl font-bold text-forest mb-6">Why {city.name} Residents Choose Mark's</h2>
      <ul class="space-y-3 text-gray-600 mb-12">
        <li class="flex items-start gap-3">
          <span class="text-green font-bold text-xl">✓</span>
          <span><strong>Perfect 5-star rating</strong> — {business.reviewCount} Google reviews from happy customers across the Upstate</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-green font-bold text-xl">✓</span>
          <span><strong>Local owner-operator</strong> — based in Greer, just minutes from {city.name}</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-green font-bold text-xl">✓</span>
          <span><strong>Free estimates via text</strong> — snap a photo, text it to us, get a quote within hours</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-green font-bold text-xl">✓</span>
          <span><strong>Same-week scheduling</strong> — no long waits for service</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-green font-bold text-xl">✓</span>
          <span><strong>Clean, professional results</strong> — we leave your yard level, tidy, and ready for what's next</span>
        </li>
      </ul>

      <div class="bg-forest text-white rounded-2xl p-8">
        <h2 class="text-2xl font-bold mb-3">Get a Free Stump Grinding Quote in {city.name}</h2>
        <p class="text-gray-200 mb-6">The fastest way to get a quote: text a photo of your stump to {business.phone}. Stand 10–15 feet back so we can see the size and access. We'll reply with a fair estimate, usually within hours.</p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href={business.phoneTel} class="bg-earth text-forest px-6 py-3 rounded-xl font-bold text-center hover:bg-amber-300 transition-colors">
            📞 Call {business.phone}
          </a>
          <a href={business.smsLink} class="bg-white/10 backdrop-blur text-white px-6 py-3 rounded-xl font-bold text-center hover:bg-white/20 transition-colors border border-white/30">
            📱 Text Us a Photo
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Other Areas -->
  <section class="py-12 bg-cream">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-xl font-bold text-forest mb-4 text-center">Also Serving Nearby Communities</h2>
      <div class="flex flex-wrap justify-center gap-2">
        {cities.filter(c => c.slug !== city.slug).map(c => (
          <a href={`/${c.slug}-sc-stump-grinding/`} class="bg-white px-3 py-1.5 rounded-lg text-sm text-forest hover:bg-earth/20 transition-colors">
            {c.name}, SC
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTA heading={`Ready to Remove That Stump in ${city.name}?`} />
</Layout>
