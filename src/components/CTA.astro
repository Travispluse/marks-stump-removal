---
import { business } from '../data/business';

interface Props {
  heading?: string;
  text?: string;
}

const { 
  heading = "Ready to Remove That Stump?",
  text = "Text us a photo for a free quote. Most estimates within hours."
} = Astro.props;
---
<section class="bg-earth py-12">
  <div class="max-w-4xl mx-auto px-4 text-center">
    <h2 class="text-3xl font-bold text-forest mb-3">{heading}</h2>
    <p class="text-forest/80 text-lg mb-6">{text}</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href={business.phoneTel} class="bg-forest text-white px-8 py-4 rounded-xl text-lg font-bold hover:bg-green transition-colors shadow-lg">
        Call {business.phone}
      </a>
      <a href={business.smsLink} class="bg-white text-forest px-8 py-4 rounded-xl text-lg font-bold hover:bg-cream transition-colors shadow-lg border-2 border-forest">
        Text Us a Photo
      </a>
    </div>
  </div>
</section>
