---
import { videos } from '../data/videos';

const pageId = "61571973964718";
const topRow = videos.slice(0, 8);
const bottomRow = videos.slice(7, 15);
---

<section class="bg-dark py-10 overflow-hidden">
  <div class="max-w-6xl mx-auto px-4 mb-6">
    <h2 class="text-2xl font-bold text-white text-center">See Our Work in Action</h2>
    <p class="text-gray-400 text-center text-sm mt-1">Real stump grinding jobs from Mark's Stump Removal &mdash; <a href={`https://www.facebook.com/${pageId}/videos/`} target="_blank" rel="noopener" class="text-earth hover:underline">Watch all on Facebook</a></p>
  </div>

  <!-- Top row - slides right -->
  <div class="carousel-wrapper mb-3">
    <div class="carousel-track carousel-right">
      {[...topRow, ...topRow].map((video) => (
        <a href={`https://www.facebook.com/${pageId}/videos/${video.id}/`} target="_blank" rel="noopener" class="carousel-item" title={video.title}>
          <div class="video-card">
            <div class="video-thumb">
              <div class="play-icon">
                <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
                  <circle cx="24" cy="24" r="24" fill="rgba(0,0,0,0.6)"/>
                  <path d="M19 14L35 24L19 34V14Z" fill="white"/>
                </svg>
              </div>
            </div>
            <p class="video-title">{video.title}</p>
          </div>
        </a>
      ))}
    </div>
  </div>

  <!-- Bottom row - slides left -->
  <div class="carousel-wrapper">
    <div class="carousel-track carousel-left">
      {[...bottomRow, ...bottomRow].map((video) => (
        <a href={`https://www.facebook.com/${pageId}/videos/${video.id}/`} target="_blank" rel="noopener" class="carousel-item" title={video.title}>
          <div class="video-card">
            <div class="video-thumb">
              <div class="play-icon">
                <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
                  <circle cx="24" cy="24" r="24" fill="rgba(0,0,0,0.6)"/>
                  <path d="M19 14L35 24L19 34V14Z" fill="white"/>
                </svg>
              </div>
            </div>
            <p class="video-title">{video.title}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .carousel-wrapper {
    overflow: hidden;
    width: 100%;
  }

  .carousel-track {
    display: flex;
    gap: 0.75rem;
    width: max-content;
  }

  .carousel-right {
    animation: slideRight 40s linear infinite;
  }

  .carousel-left {
    animation: slideLeft 40s linear infinite;
  }

  .carousel-item {
    flex-shrink: 0;
    text-decoration: none;
  }

  .video-card {
    width: 300px;
    border-radius: 12px;
    overflow: hidden;
    background: #2D6A4F;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .video-card:hover {
    transform: scale(1.03);
    box-shadow: 0 8px 24px rgba(0,0,0,0.3);
  }

  .video-thumb {
    width: 300px;
    height: 170px;
    background: linear-gradient(135deg, #1B4332 0%, #2D6A4F 50%, #D4A373 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .play-icon {
    opacity: 0.8;
    transition: opacity 0.2s;
  }

  .video-card:hover .play-icon {
    opacity: 1;
  }

  .video-title {
    padding: 0.625rem 0.75rem;
    color: white;
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @keyframes slideRight {
    0% {
      transform: translateX(-50%);
    }
    100% {
      transform: translateX(0%);
    }
  }

  @keyframes slideLeft {
    0% {
      transform: translateX(0%);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .carousel-wrapper:hover .carousel-track {
    animation-play-state: paused;
  }

  @media (max-width: 640px) {
    .video-card, .video-thumb {
      width: 240px;
    }
    .video-thumb {
      height: 136px;
    }
  }
</style>
