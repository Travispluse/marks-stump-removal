---
import { business } from '../data/business';
---
<header class="bg-forest text-white sticky top-0 z-50 shadow-lg">
  <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
    <a href="/" class="text-xl font-bold tracking-tight hover:text-earth transition-colors">
      Mark's Stump Removal
    </a>
    
    <nav class="hidden md:flex items-center gap-6 text-sm font-medium">
      <a href="/" class="hover:text-earth transition-colors">Home</a>
      <a href="/services/" class="hover:text-earth transition-colors">Services</a>
      <a href="/service-areas/" class="hover:text-earth transition-colors">Service Areas</a>
      <a href="/gallery/" class="hover:text-earth transition-colors">Gallery</a>
      <a href="/about/" class="hover:text-earth transition-colors">About</a>
      <a href="/contact/" class="hover:text-earth transition-colors">Contact</a>
      <a href={business.phoneTel} class="bg-earth text-forest px-4 py-2 rounded-lg font-bold hover:bg-amber-300 transition-colors">
        {business.phone}
      </a>
    </nav>

    <div class="flex items-center gap-3 md:hidden">
      <a href={business.phoneTel} class="bg-earth text-forest px-3 py-1.5 rounded-lg text-sm font-bold">
        Call Now
      </a>
      <button id="menu-toggle" class="text-white p-1" aria-label="Menu">
        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>

  <nav id="mobile-menu" class="hidden md:hidden bg-forest border-t border-green pb-4 px-4">
    <a href="/" class="block py-2 hover:text-earth transition-colors">Home</a>
    <a href="/services/" class="block py-2 hover:text-earth transition-colors">Services</a>
    <a href="/service-areas/" class="block py-2 hover:text-earth transition-colors">Service Areas</a>
    <a href="/gallery/" class="block py-2 hover:text-earth transition-colors">Gallery</a>
    <a href="/about/" class="block py-2 hover:text-earth transition-colors">About</a>
    <a href="/contact/" class="block py-2 hover:text-earth transition-colors">Contact</a>
  </nav>
</header>

<script>
  document.getElementById('menu-toggle')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
</script>
